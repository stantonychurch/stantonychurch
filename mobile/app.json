{
  "expo": {
    "name": "St Antony Church",
    "slug": "st-antony-church",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#1a1209"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stantony.church",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.jpg",
        "backgroundColor": "#1a1209"
      },
      "package": "com.stantony.church",
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "stantony",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2a1f9a39-b0a8-4c9c-becc-6c96e12ebed8"
      }
    }
  }
}
